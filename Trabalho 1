    {
      "cell_type": "code",
      "source": [
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# 1. Gerar 1000 amostras uniformes\n",
        "u = np.random.uniform(0, 1, 1000)\n",
        "\n",
        "# 2. Aplicar a transformação inversa x = sqrt(u)\n",
        "amostras = np.sqrt(u)\n",
        "\n",
        "# 3. Plotar o histograma e a PDF teórica\n",
        "plt.hist(amostras, bins=30, density=True, alpha=0.6, color='skyblue', label='Amostras Simuladas')\n",
        "x = np.linspace(0, 1, 100)\n",
        "plt.plot(x, 2*x, 'r-', lw=2, label='PDF Teórica $f(x)=2x$')\n",
        "plt.legend()\n",
        "plt.show()"
